{
  "buildCommand": "bash build.sh",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/transcript.py": { "maxDuration": 10 },
    "api/thumbnail.py": { "maxDuration": 10 },
    "api/gtm-data.js": { "includeFiles": "data/**" },
    "api/strategy-chat.js": { "maxDuration": 300, "includeFiles": "data/**" },
    "api/burn-upload.js": { "maxDuration": 10 },
    "api/fathom-ingest.js": { "maxDuration": 300 },
    "api/fathom-list.js": { "maxDuration": 60 },
    "api/fathom-cache.js": { "maxDuration": 60 },
    "api/notion-publish.js": { "maxDuration": 60 },
    "api/strategy-state.js": { "maxDuration": 30 },
    "api/supadata.js": { "maxDuration": 15 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/nav", "destination": "/nav.html" },
    { "source": "/pixel-setup", "destination": "/pixel-setup.html" },
    { "source": "/submit-creative", "destination": "/submit-creative.html" },
    { "source": "/investors", "destination": "/pitch-deck.html" },
    { "source": "/talking-points", "destination": "/talking-points.html" },
    { "source": "/youtube-article", "destination": "/youtube-article.html" },
    { "source": "/bi", "destination": "/bi.html" },
    { "source": "/ad-ops", "destination": "/ad-ops.html" },
    { "source": "/managed", "destination": "/managed.html" },
    { "source": "/chat", "destination": "/chat-ui.html" },
    { "source": "/ear-check", "destination": "/ear-check.html" },
    { "source": "/proposal", "destination": "/proposal.html" },
    { "source": "/strategy", "destination": "/strategy.html" },
    { "source": "/brand", "destination": "/brand.html" },
    { "source": "/titans", "destination": "/titans-of-advertising.html" },
    { "source": "/vc-offer", "destination": "/vc-offer.html" },
    { "source": "/vcfounderprogram", "destination": "/vcfounderprogram.html" },
    { "source": "/vcoffer", "destination": "/vcoffer.html" },
    { "source": "/partners", "destination": "/partners.html" }
  ]
}
